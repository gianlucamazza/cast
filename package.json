{
  "name": "cast-extension",
  "version": "0.3.1",
  "private": true,
  "description": "Firefox/LibreWolf extension that casts a media URL or mirrors the browser window/screen to a Chromecast via the native castbridge daemon.",
  "scripts": {
    "lint": "web-ext lint -c web-ext-config.mjs",
    "check:i18n": "node scripts/check-locales.mjs",
    "start": "web-ext run -c web-ext-config.mjs",
    "build": "web-ext build -c web-ext-config.mjs",
    "sign:unlisted": "web-ext sign -c web-ext-config.mjs --channel=unlisted --api-key=\"$AMO_JWT_ISSUER\" --api-secret=\"$AMO_JWT_SECRET\"",
    "sign:listed": "web-ext sign -c web-ext-config.mjs --channel=listed --amo-metadata=amo-metadata.json --api-key=\"$AMO_JWT_ISSUER\" --api-secret=\"$AMO_JWT_SECRET\""
  },
  "devDependencies": {
    "web-ext": "^10.3.0"
  },
  "overrides": {
    "shell-quote": "^1.8.4"
  }
}
